DATABASE_URL=postgresql://user:password@host/db?sslmode=require
JWT_SECRET=change-me-to-a-random-secret
JWT_REFRESH_SECRET=change-me-to-another-random-secret
PORT=3001
CORS_ORIGIN=http://localhost:4200
NODE_ENV=development
# SteamGridDB — get from https://www.steamgriddb.com/profile/preferences/api
SGDB_API_KEY=
# IGDB (Twitch API v4) — get from https://dev.twitch.tv/console/apps
IGDB_CLIENT_ID=
IGDB_ACCESS_TOKEN=
# RapidAPI — get from https://rapidapi.com/opencritic-opencritic-default/api/opencritic-api
RAPIDAPI_KEY=
