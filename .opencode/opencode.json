{
  "$schema": "https://opencode.ai/config.json",
  "small_model": "openrouter/owl-alpha",
  "provider": {
    "openrouter": {
      "models": {
        "owl-alpha": {
          "name": "Owl Alpha"
        }
      }
    }
  },
  "agent": {
    "general": {
      "model": "openrouter/owl-alpha"
    },
    "explore": {
      "model": "openrouter/owl-alpha"
    }
  },
  "mcp": {
    "context7": {
      "type": "local",
      "command": ["npx", "-y", "@upstash/context7-mcp"],
      "enabled": true,
      "env": {
        "CONTEXT7_API_KEY": "ctx7sk-cec4a442-d779-459c-81c4-a03a796e42c3"
      }
    }
  }
}
